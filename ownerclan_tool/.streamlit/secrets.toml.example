# Streamlit Community Cloud 배포용 시크릿 템플릿
# 실제 배포 시에는 아래 값을 실제 값으로 채워서
# Streamlit Cloud Dashboard > App settings > Secrets 에 붙여넣으세요.

APP_ENV = "SANDBOX"
LOG_LEVEL = "INFO"
DB_PATH = "ownerclan_tool.db"

OWNERCLAN_ENV = "sandbox"
OWNERCLAN_AUTH_URL = "https://auth-sandbox.ownerclan.com/auth"
OWNERCLAN_GRAPHQL_URL = "https://api-sandbox.ownerclan.com/v1/graphql"
OWNERCLAN_API_ID = "your_ownerclan_api_id"
OWNERCLAN_API_PW = "your_ownerclan_api_password"
OWNERCLAN_PRODUCT_KEY_VARIABLE = "key"
OWNERCLAN_AUTH_HEADER_SCHEME = "Bearer"

SMARTSTORE_BASE_URL = "https://sandbox-api.smartstore.example.com"
SMARTSTORE_REGISTER_PRODUCT_ENDPOINT = "/products"
SMARTSTORE_CLIENT_ID = "your_smartstore_client_id"
SMARTSTORE_CLIENT_SECRET = "your_smartstore_client_secret"
SMARTSTORE_API_KEY = "your_smartstore_api_key"
